
#include <iostream>
#include <stdio.h>
#include <stdlib.h>

using namespace std;

struct Rectangle 
{
    int length;
    int breadth;

void initialise(int l,int b)
{
    length=l;
    breadth=b;
}

int area()
{
    return length*breadth;
}

int perimeter()
{
    int p;
    p=2*(length+breadth);
    return p;
}

};

int main()
{
    struct Rectangle r={0,0};
    int l, b;
    printf("Enter the value of Length and breadth ");
    cin>>l>>b;
    r.initialise(l,b);
    int a=r.area();
    int peri=r.perimeter();
    
    cout<<"The area is "<<a<<endl<<"The perimeter is "<<peri<<endl;
   
    return 0;
} 
