#include <iostream>

using namespace std;

template<class T>
class Airthmetic
{
    private:
    T a;
    T b;
    
    public:
    Airthmetic(T a,T b);
    T add();
    T sub();
};
    
    template<class T>
    Airthmetic<T>::Airthmetic(T a,T b)
    {
        this->a=a;
        this->b=b;
    }
    
    template<class T>
    T Airthmetic<T>::add()
    {
        T c;
        c=a+b;
        return c;
    }
    
    template<class T>
    T Airthmetic<T>::sub()
    {
        T c;
        c=a-b;
        return c;
    }
    

int main()
{
    Airthmetic<float> ar(10.99, 5.01);
    cout<<"Add "<<ar.add()<<endl;
    cout<<"Sub "<<ar.sub()<<endl;
    return 0;
}
