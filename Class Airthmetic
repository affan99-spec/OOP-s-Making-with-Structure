#include <iostream>

using namespace std;

class Airthmetic
{
    private:
    int a;
    int b;
    
    public:
    
    Airthmetic(int a,int b)
    {
        this->a=a;
        this->b=b;
    }
    
    int add()
    {
        int c;
        c=a+b;
        return c;
    }
    
    int sub()
    {
        int c;
        c=a-b;
        return c;
    }
    
};

int main()
{
    Airthmetic ar(10, 5);
    cout<<"Add "<<ar.add()<<endl;
    cout<<"Sub "<<ar.sub()<<endl;
    return 0;
}
